# Supabase project (public).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Supabase service-role key. NEVER exposed to the client. Used server-side
# only for privileged writes, storage uploads, and signed URLs.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Direct Postgres connection string. Use the "Session pooler" or a direct
# connection to your Supabase Postgres for server-side writes.
DATABASE_URL=postgres://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?sslmode=require

# Storage bucket. Must match the bucket created by 0003_storage.sql.
WEZA_STORAGE_BUCKET=submissions

# Solana devnet. In production, point SOLANA_RPC_URL at a dedicated
# Helius / QuickNode / Triton devnet endpoint to avoid the public rate
# limiter. SOLANA_TREASURY_KEYPAIR must hold a JSON array secret key
# for a devnet keypair funded with BOTH SOL (fees + ATA rent) and
# devnet USDC from https://faucet.circle.com (mint
# 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU).
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
SOLANA_TREASURY_KEYPAIR=[12,34,...]

# Local-only flag. IGNORED in production. When set to 1 in development,
# trigger payout returns a synthetic signature and does not touch the
# network. Do not ship this flag to production environments.
# WEZA_MOCK_SOLANA=1
